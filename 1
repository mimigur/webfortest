<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700&display=swap" rel="stylesheet">

</head>
<body>

  <!-- 화면 이동 버튼 -->
  <div class="scroll-btn" id="scrollToFormBtn">
    ✍️<br>신청서<br>작성하기
  </div>

  <!-- ✅ 풀스크린 메인 배너(반응형 cover) -->
  <section class="main-banner" aria-label="메인 배너 이미지">
    <img
      src="https://www.otdads.com/ads/img/mog.png"
      alt="임플란트 메인 배너"
      class="banner-img"
      loading="eager"
    >
  </section>

  <!-- ✅ 폼 영역(가독성을 위해 max-width 유지) -->
  <div class="page-wrapper">
    <div class="content-wrapper">
<section class="form-card is-visible" id="mainFormCard">
      <!-- 상단 띠 제목 -->
      <div class="title-bar">
        임플란트 혜택가 신청
      </div>

      <!-- 폼 본문 -->
      <form id="consultForm" method="POST" action="https://script.google.com/macros/s/AKfycbzt5gVyu3Dnf-6sOzW5eFPYO7OxXAMIkYJudjiY8TNr9x8y0b54fArFZgu394TlXwai/exec">
        <!-- 1. 이름 -->
        <div class="form-group">
          <label for="name" class="form-label">성함</label>
          <input
            type="text"
            id="name"
            name="name"
            class="input-box"
            placeholder="성함을 적어주세요"
            required
          >
        </div>

        <!-- 2. 연락처 -->
        <div class="form-group">
          <label class="form-label">연락처</label>

          <div class="phone-row">
            <input
              type="text"
              class="phone-input readonly"
              value="010"
              readonly
            >
            <input
              type="text"
              id="phone2"
              class="phone-input"
              maxlength="4"
              inputmode="numeric"
              placeholder="0000"
            >
            <input
              type="text"
              id="phone3"
              class="phone-input"
              maxlength="4"
              inputmode="numeric"
              placeholder="0000"
            >
          </div>

          <!-- 서버로 보낼 최종 번호 -->
          <input type="hidden" name="phone" id="phoneFull">
        </div>

        <!-- 3. 본인 확인 + 개인정보 동의 -->
        <div class="form-group confirm-group">
          <div class="confirm-text">
            "임플란트 특가 신청이 맞으신가요?"
          </div>

          <div class="confirm-row">
            <input
              type="checkbox"
              id="confirm"
              name="confirm"
              value="yes"
            >
            <label for="confirm">네, 맞습니다.</label>
          </div>

          <div class="confirm-row privacy-row">
            <input
              type="checkbox"
              id="privacyAgree"
              name="privacyAgree"
              value="yes"
              checked
            >
            <label for="privacyAgree">개인정보처리방침 동의</label>
            <a
              href="javascript:void(0);"
              class="terms-link"
              onclick="openTermsPopup()"
            >(약관보기)</a>
          </div>
        </div>

        <!-- ★★★ UTM & 매체/소재 정보 hidden 필드 ★★★ -->
        <input type="hidden" name="utm_source"   id="utm_source">
        <input type="hidden" name="utm_medium"   id="utm_medium">
        <input type="hidden" name="utm_campaign" id="utm_campaign">
        <input type="hidden" name="utm_content"  id="utm_content">
        <input type="hidden" name="utm_term"     id="utm_term">
        <input type="hidden" name="request_id" id="request_id">

        <!-- 제출 버튼 -->
        <button type="submit" class="submit-btn">상담 신청하기</button>
      </form>
    </section>

    </div>
  </div>
<!-- ✅ 커스텀 팝업 HTML -->
  <div id="customAlertOverlay" class="alert-overlay">
    <div class="alert-box">
      <div id="customAlertMessage" class="alert-message"></div>
      <button class="alert-btn" onclick="closeCustomAlert()">확인</button>
    </div>
  </div>

  <!-- ✅ 개인정보처리방침 약관 팝업 -->
  <div id="termsOverlay" class="alert-overlay">
    <div class="alert-box terms-box">
      <img
        src="https://www.otdads.com/ads/img/agree.png"
        alt="개인정보처리방침 약관"
        class="terms-image"
      >
      <button
        class="alert-btn"
        type="button"
        onclick="closeTermsPopup()"
      >닫기</button>
    </div>
  </div>

  <script src="https://www.otdads.com/ads/yjscript.js"></script>

</body>
</html>

